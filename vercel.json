{
  "version": 2,
  "routes": [
    {
      "src": "/sw.js",
      "dest": "/public/sw.js"
    },
    {
      "src": "/nexproxy/(.*)",
      "dest": "/api/proxy.js?path=$1"
    },
    {
      "src": "/ws/(.*)",
      "dest": "/api/ws.js?path=$1"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ],
  "functions": {
    "api/proxy.js": {
      "runtime": "@vercel/edge",
      "maxDuration": 10,
      "memory": 1024
    },
    "api/ws.js": {
      "runtime": "@vercel/edge",
      "maxDuration": 10,
      "memory": 1024
    }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Service-Worker-Allowed",
          "value": "/"
        },
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ]
}
