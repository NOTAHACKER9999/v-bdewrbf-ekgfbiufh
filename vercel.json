{
  "version": 2,
  "rewrites": [
    {
      "source": "/sw.js",
      "destination": "/public/sw.js"
    },
    {
      "source": "/nexproxy/:path*",
      "destination": "/api/proxy"
    },
    {
      "source": "/ws/:path*",
      "destination": "/api/ws"
    },
    {
      "source": "/:path*",
      "destination": "/public/:path*"
    }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Service-Worker-Allowed",
          "value": "/"
        },
        {
          "key": "Cache-Control",
          "value": "no-cache"
        }
      ]
    },
    {
      "source": "/api/:path*",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    }
  ]
}
